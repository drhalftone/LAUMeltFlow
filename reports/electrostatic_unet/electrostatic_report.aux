\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Verification of the superposition principle. (a) Potential from the first 10 charges ($\phi _A$). (b) Potential from the last 10 charges ($\phi _B$). (c) Sum of individual potentials ($\phi _A + \phi _B$). (d) Error between the direct computation and the sum, showing machine-precision agreement.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:superposition}{{3}{4}{Verification of the superposition principle. (a) Potential from the first 10 charges ($\phi _A$). (b) Potential from the last 10 charges ($\phi _B$). (c) Sum of individual potentials ($\phi _A + \phi _B$). (d) Error between the direct computation and the sum, showing machine-precision agreement}{figure.caption.3}{}}
