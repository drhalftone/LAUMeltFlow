\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Verification of Poisson's equation. (a) Numerical Laplacian $\nabla ^2\phi $ computed via finite differences. (b) Negative charge density $-\rho $. The Laplacian shows localized peaks at particle positions, matching the discrete charge distribution.}}{3}{figure.caption.2}\protected@file@percent }
\newlabel{fig:poisson_verification}{{2}{3}{Verification of Poisson's equation. (a) Numerical Laplacian $\nabla ^2\phi $ computed via finite differences. (b) Negative charge density $-\rho $. The Laplacian shows localized peaks at particle positions, matching the discrete charge distribution}{figure.caption.2}{}}
